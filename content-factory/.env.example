# ── content-factory · пример окружения ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

ARTICLES_PER_DAY=5
ENABLE_EDITOR_PASS=true
USE_BATCH=true            # Batch API: −50% к цене. false → последовательный режим

# Куда писать статьи (репозиторий сайта). В GitHub Actions определяется автоматически.
SITE_REPO_PATH=/path/to/your-site-repo
SITE_REPO_URL=git@github.com:your-org/your-site.git
SITE_REPO_BRANCH=main
SITE_BLOG_DIR=content/blog

# Email-отчёт о прогоне (опционально, через Resend). Без ключа письмо печатается в лог.
RESEND_API_KEY=
EMAIL_FROM=                              # верифицированный домен в Resend
EMAIL_FROM_FALLBACK=onboarding@resend.dev
EMAIL_TO=you@example.com
