# ── content-factory · пример окружения ───────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

ARTICLES_PER_DAY=5
ENABLE_EDITOR_PASS=true
USE_BATCH=true            # Batch API: −50% к цене. false → последовательный режим

# ── distill-landing (сайт, другой репо) ───────────────────────────────
# Fine-grained PAT: Contents: write на distill-landing.
# В GitHub Actions добавить в Settings → Secrets → Actions как SITE_REPO_TOKEN.
SITE_REPO_TOKEN=github_pat_...
SITE_REPO_URL=https://github.com/your-org/distill-landing.git
SITE_REPO_BRANCH=main
SITE_BLOG_DIR=blog         # папка для HTML-статей внутри distill-landing

# Локальный режим: путь, куда клонировать distill-landing
SITE_REPO_PATH=/path/to/distill-landing

# ── Сайт ──────────────────────────────────────────────────────────────
SITE_URL_BASE=https://example.com

# ── CTA-блок в конце каждой статьи (опционально) ──────────────────────
CTA_HEADING=Получайте разборы раз в неделю
CTA_TEXT=Каждую неделю — одна большая идея из мира продуктивности и мышления.
CTA_BUTTON=Подписаться на дайджест
CTA_HREF=/newsletter/

# ── Email-отчёт о прогоне (опционально, через Resend) ─────────────────
RESEND_API_KEY=
EMAIL_FROM=
EMAIL_FROM_FALLBACK=onboarding@resend.dev
EMAIL_TO=you@example.com
