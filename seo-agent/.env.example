# ── seo-agent · пример окружения ──────────────────────────────────────
# Скопируйте в .env (для локального запуска) ИЛИ задайте как GitHub Secrets.
# .env закоммичен в .gitignore — реальные ключи в репозиторий не попадут.

# Claude (стратег, M1-кластеризация). console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# Доставка отчётов в Telegram
TELEGRAM_BOT_TOKEN=123456:ABC...        # @BotFather
TELEGRAM_CHAT_ID=-1001234567890         # @userinfobot или getUpdates

# Адрес сайта (меняется на каждом проекте)
SEO_SITE_DOMAIN=example.com
GSC_SITE_URL=sc-domain:example.com      # или https://example.com/ для URL-prefix
M2_SITE_ROOT=https://example.com        # корень для краулинга sitemap

# Google Search Console (OAuth). Refresh-токен: python3 modules/gsc_oauth_setup.py
GSC_OAUTH_CLIENT_ID=...apps.googleusercontent.com
GSC_OAUTH_CLIENT_SECRET=...
GSC_OAUTH_REFRESH_TOKEN=...
# Опубликуйте OAuth-приложение в Production, иначе refresh-токен живёт ~7 дней.

# Яндекс.Вебмастер (OAuth access_token, scope webmaster:hostinfo,verify)
YANDEX_WEBMASTER_TOKEN=...
# Опционально (ускоряет — иначе резолвится по домену автоматически):
YANDEX_WEBMASTER_USER_ID=
YANDEX_WEBMASTER_HOST_ID=

# PageSpeed Insights (Core Web Vitals). Google Cloud Console → PSI API
PSI_API_KEY=...

# Topvisor — позиции в Яндексе (опционально). topvisor.com → Настройки → API
TOPVISOR_API_TOKEN=
TOPVISOR_USER_ID=
TOPVISOR_PROJECT_ID=

# Быстрая индексация (опционально). Ключ кладётся в public/<key>.txt сайта
INDEXNOW_KEY=
INDEXNOW_HOST=example.com
